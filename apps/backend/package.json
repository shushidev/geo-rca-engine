{
  "name": "@geo-rca-engine/backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "lint": "eslint '{src,test}/**/*.ts' --fix",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "migrate:make": "knex --knexfile knexfile.ts migrate:make",
    "migrate:latest": "knex --knexfile knexfile.ts migrate:latest",
    "migrate:rollback": "knex --knexfile knexfile.ts migrate:rollback",
    "migrate:status": "knex --knexfile knexfile.ts migrate:status"
  },
  "dependencies": {
    "@nestjs/common": "^10.2.3",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^10.2.3",
    "@nestjs/platform-express": "^10.2.3",
    "@pinecone-database/pinecone": "^7.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "knex": "^3.2.10",
    "openai": "^6.42.0",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.2.3",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.2.3",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.57.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.5.4"
  }
}
